# Copy to .env.local (this file is gitignored)

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=big_event
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend server port
SERVER_PORT=8081

# Optional: override frontend proxy target directly
# BACKEND_URL=http://localhost:8081
